# ==============================================
# RPSA — Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (required)
# For Vercel Postgres: provided automatically when you link a Vercel Postgres database
# For Neon / Supabase / Railway: use the pooled connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
